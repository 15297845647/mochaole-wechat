.container {
  padding: 30px 20px;
  background: #1A1A1A;
  min-height: 100vh;
  box-sizing: border-box;
}

.title {
  font-size: 28px;
  font-weight: 700;
  color: #D4AF37;
  text-align: center;
}

.subtitle {
  font-size: 14px;
  color: #666;
  text-align: center;
  margin-top: 8px;
  margin-bottom: 30px;
}

.form {
  
}

.form-item {
  margin-bottom: 24px;
}

.label {
  font-size: 14px;
  color: #888;
  margin-bottom: 8px;
}

.input {
  width: 100%;
  height: 48px;
  background: #333;
  border-radius: 12px;
  padding: 0 16px;
  color: #fff;
  font-size: 15px;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  height: 80px;
  background: #333;
  border-radius: 12px;
  padding: 12px 16px;
  color: #fff;
  font-size: 15px;
  box-sizing: border-box;
}

.avatar-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.avatar-item {
  width: 50px;
  height: 50px;
  background: #333;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  border: 2px solid transparent;
}

.avatar-item.selected {
  border-color: #D4AF37;
}

.btn-primary {
  width: 100%;
  height: 50px;
  background: #D4AF37;
  border: none;
  border-radius: 25px;
  color: #1A1A1A;
  font-size: 16px;
  font-weight: 600;
  line-height: 50px;
  margin-top: 20px;
}
