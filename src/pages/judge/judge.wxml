<view class="container">
  <scroll-view class="chat-area" scroll-y="true" scroll-into-view="{{scrollIntoView}}">
    <block wx:for="{{messages}}" wx:key="id">
      <view class="message message-a" wx:if="{{item.sender === 'partyA'}}">
        <view class="avatar">A</view>
        <view class="bubble">{{item.content}}</view>
      </view>
      <view class="message message-b" wx:if="{{item.sender === 'partyB'}}">
        <view class="bubble">{{item.content}}</view>
        <view class="avatar">B</view>
      </view>
      <view class="message message-system" wx:if="{{item.sender === 'system'}}">
        <view class="bubble system">{{item.content}}</view>
      </view>
      <view class="message message-result" wx:if="{{item.sender === 'result'}}">
        <view class="bubble result">
          <view class="result-title">🧑‍⚖️ 判决结果</view>
          <view class="result-winner">{{item.winner}}</view>
          <view class="result-reason">{{item.reason}}</view>
        </view>
      </view>
    </block>
    <view id="bottom"></view>
  </scroll-view>

  <view class="input-area">
    <input class="chat-input" placeholder="输入你的观点..." value="{{inputText}}" bindinput="onInput" bindconfirm="sendMessage"/>
    <button class="send-btn" bindtap="sendMessage">发送</button>
  </view>

  <view class="end-btn" bindtap="endDebate">
    <text>结束争吵 👉 判官裁决</text>
  </view>
</view>
