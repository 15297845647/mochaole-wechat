<view class="container">
  <!-- 历史记录列表 -->
  <view wx:if="{{!selectedRecord}}">
    <view class="page-title">历史记录 ({{history.length}})</view>
    
    <view wx:if="{{history.length === 0}}" class="empty">
      <text>暂无历史记录</text>
    </view>

    <view class="history-list">
      <view class="history-item" wx:for="{{history}}" wx:key="id" bindtap="viewRecord" data-id="{{item.id}}">
        <view class="history-header">
          <view class="history-winner">{{item.winner}}</view>
          <view class="history-meta">
            <text class="history-mode">{{item.mode === 'anonymous' ? '匿名' : '实名'}}</text>
            <text class="history-style">{{item.style}}</text>
          </view>
        </view>
        <view class="history-preview">{{item.reason}}</view>
        <view class="history-footer">
          <text>{{item.date}}</text>
          <text>{{item.messageCount}}条对话</text>
        </view>
      </view>
    </view>

    <button class="btn-primary" bindtap="backToHome">返回首页</button>
  </view>

  <!-- 历史记录详情 -->
  <view wx:if="{{selectedRecord}}">
    <view class="detail-header">
      <button class="back-btn" bindtap="closeRecord">← 返回</button>
      <text class="detail-title">吵架详情</text>
    </view>

    <!-- 吵架过程 -->
    <scroll-view class="detail-chat" scroll-y="true">
      <block wx:for="{{selectedRecord.messages}}" wx:key="id">
        <view class="message message-a" wx:if="{{item.sender === 'partyA'}}">
          <view class="avatar">A</view>
          <view class="bubble">{{item.content}}</view>
        </view>
        <view class="message message-b" wx:if="{{item.sender === 'partyB'}}">
          <view class="bubble">{{item.content}}</view>
          <view class="avatar">B</view>
        </view>
      </block>
    </scroll-view>

    <!-- 判决结果 -->
    <view class="detail-result">
      <view class="result-title">🧑‍⚖️ 判决结果</view>
      
      <view class="winner-card">
        <view class="winner-label">胜者</view>
        <view class="winner-name">{{selectedRecord.winner}}</view>
      </view>

      <view class="score-card" wx:if="{{selectedRecord.scores}}">
        <view class="score-title">六维评分</view>
        <view class="score-item" wx:for="{{selectedRecord.scores}}" wx:key="label">
          <view class="score-label">{{item.label}}</view>
          <view class="score-bar">
            <view class="score-fill {{item.score}}" style="width: {{item.value}}%"></view>
          </view>
          <view class="score-value">{{item.value}}分</view>
        </view>
      </view>

      <view class="reason-card">
        <view class="reason-title">判决理由</view>
        <view class="reason-content">{{selectedRecord.reason}}</view>
      </view>

      <view class="highlight" wx:if="{{selectedRecord.highlight}}">
        <view class="highlight-label">金句</view>
        <view class="highlight-content">{{selectedRecord.highlight}}</view>
      </view>

      <view class="meta-info">
        <text>模式: {{selectedRecord.mode === 'anonymous' ? '匿名' : '实名'}}</text>
        <text>风格: {{selectedRecord.style}}</text>
        <text>对话: {{selectedRecord.messageCount}}条</text>
      </view>
    </view>
  </view>
</view>
