.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #1A1A1A;
}

.chat-area {
  flex: 1;
  padding: 16px;
  padding-bottom: 10px;
}

.message {
  display: flex;
  margin-bottom: 16px;
  align-items: flex-start;
}

.message-a {
  justify-content: flex-start;
}

.message-b {
  justify-content: flex-end;
}

.message-system {
  justify-content: center;
}

.message-system .bubble {
  background: transparent;
  color: #888;
  font-size: 13px;
  text-align: center;
}

.message-result {
  justify-content: center;
}

.message-result .bubble {
  background: linear-gradient(135deg, #333, #1A1A1A);
  border: 2px solid #D4AF37;
  border-radius: 16px;
}

.result-title {
  font-size: 16px;
  font-weight: 700;
  color: #D4AF37;
  text-align: center;
  margin-bottom: 12px;
}

.result-winner {
  font-size: 20px;
  font-weight: 700;
  color: #4CAF50;
  text-align: center;
  margin-bottom: 12px;
}

.result-reason {
  font-size: 14px;
  color: #ccc;
  line-height: 1.6;
}

.avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
  flex-shrink: 0;
}

.message-a .avatar {
  background: #E74C3C;
  margin-right: 10px;
}

.message-b .avatar {
  background: #3498DB;
  margin-left: 10px;
}

.bubble {
  max-width: 70%;
  padding: 12px 16px;
  border-radius: 16px;
  font-size: 15px;
  line-height: 1.5;
  word-break: break-all;
}

.message-a .bubble {
  background: #333;
  border-top-left-radius: 4px;
}

.message-b .bubble {
  background: #8B0000;
  border-top-right-radius: 4px;
}

.input-area {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background: #252525;
  border-top: 1px solid #333;
}

.chat-input {
  flex: 1;
  height: 40px;
  background: #333;
  border-radius: 20px;
  padding: 0 16px;
  color: #fff;
  font-size: 15px;
}

.send-btn {
  width: 70px;
  height: 40px;
  background: #D4AF37;
  border: none;
  border-radius: 20px;
  color: #1A1A1A;
  font-size: 15px;
  font-weight: 600;
  margin-left: 12px;
  line-height: 40px;
}

.end-panel {
  padding: 16px;
  background: #252525;
  border-top: 1px solid #333;
}

.end-status {
  text-align: center;
  margin-bottom: 12px;
}

.end-status-text {
  color: #D4AF37;
  font-size: 14px;
}

.end-status-text.waiting {
  color: #888;
}

.end-btn {
  width: 100%;
  height: 44px;
  background: #D4AF37;
  border: none;
  border-radius: 22px;
  color: #1A1A1A;
  font-size: 15px;
  font-weight: 600;
  line-height: 44px;
  margin-bottom: 8px;
}

.end-btn.agreed {
  background: #4CAF50;
  color: #fff;
}

.end-btn.cancel {
  background: #666;
  color: #fff;
}
