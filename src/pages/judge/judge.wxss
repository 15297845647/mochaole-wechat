.page-title {
  font-size: 24px;
  font-weight: 700;
  color: #D4AF37;
  text-align: center;
  margin-bottom: 32px;
}

.mode-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #333, #1A1A1A);
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 16px;
  border: 2px solid #444;
}

.mode-icon {
  font-size: 40px;
  margin-right: 16px;
}

.mode-name {
  font-size: 16px;
  font-weight: 600;
  color: #fff;
}

.mode-desc {
  font-size: 12px;
  color: #666;
  margin-top: 4px;
}

.input-group {
  margin-bottom: 20px;
}

.input-label {
  font-size: 14px;
  color: #888;
  margin-bottom: 8px;
}

.vs {
  text-align: center;
  font-size: 20px;
  font-weight: 700;
  color: #D4AF37;
  margin: 20px 0;
}

.form-group {
  margin-bottom: 24px;
}

.form-label {
  font-size: 14px;
  color: #888;
  margin-bottom: 8px;
}

.avatar-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.avatar-option {
  width: 50px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  background: #333;
  border-radius: 12px;
  border: 2px solid #444;
}

.stats-grid {
  display: flex;
  gap: 12px;
  margin-bottom: 24px;
}

.stat-card {
  flex: 1;
  background: #333;
  border-radius: 12px;
  padding: 16px;
  text-align: center;
}

.stat-num {
  font-size: 24px;
  font-weight: 700;
  color: #D4AF37;
}

.stat-label {
  font-size: 12px;
  color: #666;
  margin-top: 4px;
}

.invite-section {
  background: linear-gradient(135deg, #8B0000, #C41E3A);
  border-radius: 12px;
  padding: 20px;
  text-align: center;
}

.invite-title {
  font-size: 14px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12px;
}

.invite-code {
  margin-top: 20px;
  background: #333;
  border-radius: 12px;
  padding: 20px;
  text-align: center;
}

.code-label {
  font-size: 12px;
  color: #666;
  margin-bottom: 8px;
}

.code-value {
  font-size: 28px;
  font-weight: 700;
  color: #D4AF37;
  letter-spacing: 4px;
  font-family: monospace;
  margin-bottom: 12px;
}
