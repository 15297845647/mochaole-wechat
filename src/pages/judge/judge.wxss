.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #1A1A1A;
}

.chat-area {
  flex: 1;
  padding: 16px;
}

.message {
  display: flex;
  margin-bottom: 16px;
  align-items: flex-start;
}

.message-a {
  justify-content: flex-start;
}

.message-b {
  justify-content: flex-end;
}

.message-system {
  justify-content: center;
}

.message-system .bubble {
  background: transparent;
  color: #888;
  font-size: 13px;
  text-align: center;
}

.avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
  flex-shrink: 0;
}

.message-a .avatar {
  background: #E74C3C;
  margin-right: 10px;
}

.message-b .avatar {
  background: #3498DB;
  margin-left: 10px;
}

.bubble {
  max-width: 70%;
  padding: 12px 16px;
  border-radius: 16px;
  font-size: 15px;
  line-height: 1.5;
  word-break: break-all;
}

.message-a .bubble {
  background: #333;
  border-top-left-radius: 4px;
}

.message-b .bubble {
  background: #8B0000;
  border-top-right-radius: 4px;
}

.input-area {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background: #252525;
  border-top: 1px solid #333;
}

.chat-input {
  flex: 1;
  height: 40px;
  background: #333;
  border-radius: 20px;
  padding: 0 16px;
  color: #fff;
  font-size: 15px;
}

.send-btn {
  width: 70px;
  height: 40px;
  background: #D4AF37;
  border: none;
  border-radius: 20px;
  color: #1A1A1A;
  font-size: 15px;
  font-weight: 600;
  margin-left: 12px;
  line-height: 40px;
}
