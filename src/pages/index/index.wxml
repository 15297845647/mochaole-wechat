<view class="container">
  <!-- 顶部装饰 -->
  <view class="top-decoration"></view>
  
  <!-- Logo 和标题 -->
  <view class="header">
    <image class="logo-img" src="/images/logo.png" mode="aspectFit"/>
    <view class="title">莫吵了</view>
    <view class="subtitle">让你的架白吵</view>
  </view>

  <!-- 主功能按钮 -->
  <view class="main-btn" bindtap="startDebate">
    <view class="main-btn-icon">💬</view>
    <view class="main-btn-text">开始对喷</view>
    <view class="main-btn-desc">两人对战，AI判官裁决</view>
  </view>

  <!-- 次要功能 -->
  <view class="sub-buttons">
    <view class="sub-btn" bindtap="becomeJudge">
      <text class="sub-btn-icon">🧑‍⚖️</text>
      <text class="sub-btn-text">成为判官</text>
    </view>
    <view class="sub-btn" bindtap="viewHistory">
      <text class="sub-btn-icon">📜</text>
      <text class="sub-btn-text">历史记录</text>
    </view>
  </view>
</view>

