<view class="container">
  <!-- 顶部装饰 -->
  <view class="top-decoration"></view>
  
  <!-- Logo 和标题 -->
  <view class="header">
    <view class="logo">⚖️</view>
    <view class="title">莫吵了</view>
    <view class="subtitle">让你的架白吵</view>
  </view>

  <!-- 功能按钮 -->
  <view class="buttons">
    <button class="btn-primary" bindtap="startDebate">开始吵架</button>
    <button class="btn-secondary" bindtap="becomeJudge">成为判官</button>
    <button class="btn-secondary" bindtap="viewHistory">历史记录</button>
  </view>

  <!-- 判官入口 -->
  <view class="judge-section" bindtap="enterJudgeDashboard">
    <view class="judge-icon">🧑‍⚖️</view>
    <view class="judge-text">
      <view class="judge-title">判官入口</view>
      <view class="judge-desc">管理你的法庭</view>
    </view>
    <view class="arrow">→</view>
  </view>
</view>
