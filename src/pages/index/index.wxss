.container {
  padding: 20px;
  min-height: 100vh;
  background: #1A1A1A;
  box-sizing: border-box;
}

.top-decoration {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 120px;
  background: linear-gradient(180deg, #8B0000 0%, transparent 100%);
  z-index: 0;
}

.header {
  text-align: center;
  margin-top: 40px;
  margin-bottom: 40px;
  position: relative;
  z-index: 1;
}

.logo {
  font-size: 72px;
  margin-bottom: 16px;
}

.title {
  font-size: 32px;
  font-weight: 700;
  color: #D4AF37;
  margin-bottom: 8px;
}

.subtitle {
  font-size: 14px;
  color: #666;
}

.main-btn {
  background: linear-gradient(135deg, #8B0000, #C41E3A);
  border-radius: 20px;
  padding: 30px;
  text-align: center;
  margin-bottom: 24px;
  border: 2px solid #D4AF37;
}

.main-btn-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.main-btn-text {
  font-size: 24px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8px;
}

.main-btn-desc {
  font-size: 13px;
  color: rgba(255,255,255,0.7);
}

.sub-buttons {
  display: flex;
  gap: 16px;
}

.sub-btn {
  flex: 1;
  background: #333;
  border-radius: 16px;
  padding: 20px;
  text-align: center;
}

.sub-btn-icon {
  font-size: 32px;
  display: block;
  margin-bottom: 8px;
}

.sub-btn-text {
  font-size: 14px;
  color: #fff;
}
